---
import Heading from "@components/display/Heading.astro";
import Container from "@components/layout/Container.astro";
import Frame from "@components/layout/Frame.astro";
import Grid from "@components/layout/Grid.astro";
import Section from "@components/layout/Section.astro";
import Stack from "@components/layout/Stack.astro";
import { Image } from "astro:assets";
import { getCollection, type InferEntrySchema } from "astro:content";

type Section_ = NonNullable<InferEntrySchema<"pages">["sections"]>[number];

interface Props {
  block: Extract<Section_, { type: "pressBlock" }>;
  index: number;
}

const { block } = Astro.props;
const { id, heading } = block;

const press = await getCollection("press");

const items = press.slice().sort((a, b) => {
  const da = new Date(a.data.date).getTime();
  const db = new Date(b.data.date).getTime();
  return db - da;
});

const dateFmt = new Intl.DateTimeFormat("en-GB", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<Section id={id} class="PressBlock" padding="xl">
  <Container>
    <Stack space="2xl">
      {heading && <Heading as="h1" set:html={heading} data-reveal />}

      <Grid minItemWidth="20rem" space="xl-3xl" class="press-grid">
        {
          items.map(item => {
            const { title, source, date, image, description, link } = item.data;
            const displayDate = date ? dateFmt.format(new Date(date)) : "";
            return (
              <a
                class="press-card"
                href={link}
                target="_blank"
                rel="noopener noreferrer"
              >
                {image?.src && (
                  <Frame ratio="4/3" class="press-image">
                    {typeof image.src === "string" ? (
                      <img src={image.src} alt={image.alt ?? title} />
                    ) : (
                      <Image
                        src={image.src}
                        alt={image.alt ?? title}
                        width={800}
                        height={600}
                      />
                    )}
                  </Frame>
                )}
                <Stack space="sm" class="press-body">
                  <Heading as="h2" size="2" set:html={title} />
                  <div class="press-meta">
                    <span class="press-source">{source}</span>
                    {displayDate && (
                      <>
                        <span class="press-sep" aria-hidden="true">
                          |
                        </span>
                        <time datetime={date}>{displayDate}</time>
                      </>
                    )}
                  </div>
                  {description && (
                    <p class="press-description">{description}</p>
                  )}
                </Stack>
              </a>
            );
          })
        }
      </Grid>
    </Stack>
  </Container>
</Section>

<style>
  .PressBlock {
    padding-block-start: calc(var(--space-xl) + var(--header-height));
    padding-block-end: var(--space-3xl);
  }

  .press-grid {
    /* grid-template-columns: repeat(auto-fit, minmax(min(20rem, 100%), 1fr)); */
  }

  .press-card {
    display: block;
    color: inherit;
    text-decoration: none;
    transition: all 0.3s ease;
  }

  .press-card:hover {
    opacity: 0.75;
    transform: translateY(-0.15em);
  }

  .press-card:hover :global(h2) {
    /* text-decoration: underline;
    text-underline-offset: 0.15em; */
  }

  .press-image {
    margin-bottom: var(--space-md);
  }

  .press-meta {
    font-size: var(--font-size);
    /* text-transform: uppercase; */
    /* letter-spacing: 0.05em; */
    /* opacity: 0.7; */
  }

  .press-sep {
    margin-inline: 0.4em;
  }

  .press-description {
    margin-top: var(--space-2xs);
    max-width: 50ch;
  }
</style>
