---
import Container from "@components/layout/Container.astro";
import Section from "@components/layout/Section.astro";
import Stack from "@components/layout/Stack.astro";
import Sidebar from "@components/layout/Sidebar.astro";
import Frame from "@components/layout/Frame.astro";
import Heading from "@components/display/Heading.astro";
import Prose from "@components/display/Prose.astro";
import { Image } from "astro:assets";
import type { InferEntrySchema } from "astro:content";

type Section_ = NonNullable<InferEntrySchema<"pages">["sections"]>[number];

interface Props {
  block: Extract<Section_, { type: "peopleBlock" }>;
  index: number;
}

const { block } = Astro.props;
const { id, heading, people = [] } = block;
---

<Section id={id} class="PeopleBlock" padding="xl">
  <Container size="full">
    <div class="people-layout">
      {
        heading && (
          <div class="heading-pin">
            <Heading as="h2" size="heading-xl" font="heading" set:html={heading} />
          </div>
        )
      }

      <Stack space="3xl" class="people-list">
        {
          people.map((person) => (
            <Sidebar side="left" sideWidth="38%" space="2xl" class="person">
              <Frame ratio="3/4" class="person-image">
                {typeof person.image === "string" ? (
                  <img src={person.image} alt={person.imageAlt ?? person.name} />
                ) : (
                  <Image src={person.image} alt={person.imageAlt ?? person.name} />
                )}
              </Frame>
              <Stack space="md" class="person-body">
                <Heading as="h3" size="2" set:html={person.name} />
                {person.bio && (
                  <Prose>
                    <Fragment set:html={person.bio} />
                  </Prose>
                )}
              </Stack>
            </Sidebar>
          ))
        }
      </Stack>
    </div>
  </Container>
</Section>

<style>
  .PeopleBlock {
    .people-layout {
      position: relative;
    }

    .heading-pin {
      position: sticky;
      bottom: var(--space-lg);
      top: auto;
      align-self: end;
      z-index: 1;
      pointer-events: none;
      /* TODO: refine — sits fixed at bottom-left of block, overlaps images on scroll */
    }

    .heading-pin :global(*) {
      pointer-events: auto;
    }

    /* TODO: refine final styling */
  }
</style>
