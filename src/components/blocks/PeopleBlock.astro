---
import Heading from "@components/display/Heading.astro";
import Prose from "@components/display/Prose.astro";
import Container from "@components/layout/Container.astro";
import Frame from "@components/layout/Frame.astro";
import Section from "@components/layout/Section.astro";
import Stack from "@components/layout/Stack.astro";
import { SITE } from "@config";
import { getImage, Image } from "astro:assets";
import type { InferEntrySchema } from "astro:content";
import { buildPerson } from "../../lib/seo";

type Section_ = NonNullable<InferEntrySchema<"pages">["sections"]>[number];

interface Props {
  block: Extract<Section_, { type: "peopleBlock" }>;
  index: number;
}

const { block } = Astro.props;
const { id, heading, people = [] } = block;

// --- Build Person JSON-LD for each advisor (E-E-A-T signal).
const siteUrl = Astro.site?.href.replace(/\/$/, "") ?? SITE.website;
const pageUrl = Astro.url.href.split("#")[0];

const personSchemas = await Promise.all(
  people.map(async person => {
    let imageUrl = "";
    if (person.image?.src) {
      if (typeof person.image.src === "string") {
        imageUrl = person.image.src;
      } else {
        const processed = await getImage({
          src: person.image.src,
          width: 800,
          format: "webp",
        });
        imageUrl = new URL(processed.src, siteUrl).href;
      }
    }
    const anchor = person.name
      .toLowerCase()
      .replace(/[^a-z0-9]+/g, "-")
      .replace(/^-|-$/g, "");
    return buildPerson(
      { name: person.name, bio: person.bio, image: imageUrl },
      pageUrl,
      siteUrl,
      anchor
    );
  })
);

const personGraph = {
  "@context": "https://schema.org",
  "@graph": personSchemas,
};
---

<script type="application/ld+json" set:html={JSON.stringify(personGraph)} />

<Section id={id} class="PeopleBlock" padding="xl">
  <Container>
    <div class="relative">
      {
        heading && (
          <div class="heading-pin">
            <Heading as="h1" set:html={heading} data-reveal />
          </div>
        )
      }

      <Stack space="3xl-5xl" class="people-list">
        {
          people.map(person => (
            <div
              class="person"
              id={person.name
                .toLowerCase()
                .replace(/[^a-z0-9]+/g, "-")
                .replace(/^-|-$/g, "")}
            >
              <Heading
                as="h2"
                size="2"
                set:html={person.name}
                class="person-mobileHeading"
                data-reveal
                style="--reveal-delay: 0.15s;"
              />
              {person.image?.src && (
                <Frame
                  ratio="3/4"
                  class="person-image"
                  data-reveal
                  style="--reveal-delay: 0.3s;"
                >
                  <Image
                    src={person.image.src as string}
                    alt={person.image.alt ?? person.name}
                    width={650}
                    height={865}
                  />
                </Frame>
              )}
              <Stack space="lg" class="person-body" data-reveal>
                <Heading
                  as="h3"
                  size="2"
                  set:html={person.name}
                  class="person-desktopHeading"
                />
                {person.bio && (
                  <Prose>
                    <Fragment set:html={person.bio} />
                  </Prose>
                )}
              </Stack>
            </div>
          ))
        }
      </Stack>
    </div>
  </Container>
</Section>

<style>
  .PeopleBlock {
    padding-block-start: calc(var(--space-xl) + var(--header-height));
    padding-block-end: var(--space-3xl);

    .heading-pin {
      position: fixed;
      bottom: var(--space-md);
      top: auto;
      align-self: end;
      z-index: 1;
      pointer-events: none;
      /* mix-blend-mode: difference; */

      @media (--sm) {
        /* position: static;
        margin-bottom: var(--space-3xl); */
      }
    }

    .heading-pin :global(*) {
      pointer-events: auto;
    }

    .person {
      display: flex;
      /* justify-content: space-between; */
      align-items: start;
      gap: var(--space-xl-4xl);

      @media (--md) {
        gap: var(--space-3xl);
      }

      @media (--sm) {
        flex-direction: column;
        gap: var(--space-lg);
      }
    }

    .person-mobileHeading {
      display: none;

      @media (--sm) {
        display: block;
      }
    }

    .person-desktopHeading {
      display: block;

      @media (--sm) {
        display: none;
      }
    }

    .person-image {
      /* flex-shrink: 0; */
      /* width: ruler.fluid(120, 200); */
      /* max-width: 650px; */
      /* flex-basis: 50%; */

      @media (--sm) {
        width: calc(100vw);
        margin-left: calc(var(--container-padding) * -1);
        max-width: unset;
      }
    }

    .person-body {
      flex-basis: 40%;
      flex-shrink: 0;
      margin-left: auto;
      max-width: 65ch;

      @media (--sm) {
        flex-basis: 100%;
        margin-left: 0;
      }
    }

    /* TODO: refine final styling */
  }
</style>
