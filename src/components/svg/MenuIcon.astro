---
interface Props extends astroHTML.JSX.SVGAttributes {}

const { class: className, id, ...rest } = Astro.props;
---

<svg
  class={className}
  id={id}
  width="48"
  height="53"
  viewBox="0 0 48 53"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  {...rest}
>
  <line
    class="menuIconLine menuIconLine--top"
    x1="8"
    y1="15.5"
    x2="40"
    y2="15.5"
    stroke="currentcolor"
    stroke-width="2.25"
    stroke-linecap="square"
  ></line>
  <line
    class="menuIconLine menuIconLine--mid"
    x1="8"
    y1="26"
    x2="40"
    y2="26"
    stroke="currentcolor"
    stroke-width="2.25"
    stroke-linecap="square"
  ></line>
  <line
    class="menuIconLine menuIconLine--bot"
    x1="8"
    y1="36.5"
    x2="40"
    y2="36.5"
    stroke="currentcolor"
    stroke-width="2.25"
    stroke-linecap="square"
  ></line>
</svg>
