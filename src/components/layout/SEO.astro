---
/**
 * SEO.astro — head meta + JSON-LD structured data.
 *
 * Emits <title>, description, Open Graph tags, and a single application/ld+json
 * `@graph` containing Organization, ProfessionalService, WebSite, WebPage, and
 * (optionally) BreadcrumbList. Pages can append more nodes via `extraSchemaNodes`.
 *
 * Business details (logo, socials, contact, founding date) live in
 * src/content/settings.json so the client can edit them via Pages CMS.
 */

import type { ImageMetadata } from "astro";
import { getImage } from "astro:assets";
import { SITE } from "@config";
import {
  buildBreadcrumbs,
  buildGraph,
  buildOrganization,
  buildProfessionalService,
  buildWebPage,
  buildWebSite,
  settings,
} from "../../lib/seo";

interface Props {
  title?: string;
  description?: string;
  ogImage?: ImageMetadata | string;
  /** Override the WebPage description (defaults to `description`). */
  pageDescription?: string;
  /** Optional crumb trail: [{name, url}]. Auto-derived from pathname if omitted. */
  breadcrumbs?: { name: string; url: string }[];
  /** Page-specific JSON-LD nodes to merge into the graph (e.g. Person, Article). */
  extraSchemaNodes?: unknown[];
}

const {
  title = SITE.seo.title,
  description = SITE.seo.description,
  ogImage,
  pageDescription,
  breadcrumbs,
  extraSchemaNodes = [],
} = Astro.props;

// --- OG image: prop → SITE default, resolve to absolute URL.
const resolved = ogImage ?? SITE.seo.image;
let ogImageUrl: string;
if (typeof resolved === "string") {
  ogImageUrl = resolved.startsWith("http") ? resolved : new URL(resolved, Astro.site).href;
} else {
  const processed = await getImage({ src: resolved, width: 1200, format: "webp" });
  ogImageUrl = new URL(processed.src, Astro.site).href;
}

// --- JSON-LD graph.
const siteUrl = Astro.site?.href.replace(/\/$/, "") ?? SITE.website;
const pageUrl = Astro.url.href;

// Auto-derive breadcrumbs from pathname if not provided and not on home.
let crumbs = breadcrumbs;
if (!crumbs && Astro.url.pathname !== "/") {
  const segments = Astro.url.pathname.replace(/^\/|\/$/g, "").split("/");
  crumbs = [
    { name: "Home", url: `${siteUrl}/` },
    ...segments.map((seg, i) => ({
      name: seg.replace(/-/g, " ").replace(/\b\w/g, c => c.toUpperCase()),
      url: `${siteUrl}/${segments.slice(0, i + 1).join("/")}`,
    })),
  ];
}

const graph = buildGraph([
  buildOrganization(settings, siteUrl),
  buildProfessionalService(settings, siteUrl),
  buildWebSite(settings, siteUrl),
  buildWebPage({
    url: pageUrl,
    name: title,
    description: pageDescription ?? description,
    siteUrl,
  }),
  crumbs ? buildBreadcrumbs(crumbs) : null,
  ...extraSchemaNodes,
]);
---

<title>{title}</title>
<meta name="description" content={description} />

<!-- Open Graph -->
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={ogImageUrl} />
<meta property="og:url" content={Astro.url.href} />
<meta property="og:type" content="website" />
<meta property="og:site_name" content={SITE.author} />

<!-- JSON-LD structured data -->
<script type="application/ld+json" set:html={JSON.stringify(graph)} />
