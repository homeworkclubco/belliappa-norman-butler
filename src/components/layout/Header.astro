---
import MonogramIcon from "@components/svg/MonogramIcon.astro";
import Cluster from "./Cluster.astro";
import Container from "./Container.astro";
import MenuToggle from "./MenuToggle.astro";
import Section from "./Section.astro";

interface Props {
  hideTrigger?: boolean;
}

const { hideTrigger = false } = Astro.props;

const isHome = Astro.url.pathname === "/" || Astro.url.pathname === "";

const navLinks = [
  { href: "/work", label: "Work" },
  { href: "/people", label: "People" },
  { href: "/contact", label: "Enquiries" },
];

const mobileNavLinksHtml = navLinks
  .map(
    link =>
      `<li><a href="${link.href}" @click="menuOpen = false">${link.label}</a></li>`
  )
  .join("");
---

<Section
  as="header"
  class="site-header"
  x-data="{
    menuOpen: false,
    isScrolled: false,
    syncScrollState() {
      this.isScrolled = window.scrollY > 100;
    },
    syncHeaderHeight() {
      document.documentElement.style.setProperty('--header-height', this.$el.offsetHeight + 'px');
    },
    init() {
      this.$watch('menuOpen', value => {
        document.body.style.overflow = value ? 'hidden' : '';
      });

      this.syncScrollState();
      this.syncHeaderHeight();
      window.addEventListener('scroll', () => this.syncScrollState(), { passive: true });
      window.addEventListener('resize', () => this.syncHeaderHeight(), { passive: true });
    },
  }"
  @open-nav.window="menuOpen = true; $nextTick(() => $refs.closeBtn?.focus())"
  :data-scrolled="isScrolled.toString()"
  :class="{ 'is-scrolled': isScrolled }"
>
  {
    !hideTrigger && (
      <Container size="full">
        <Cluster justify="start" class="start">
          <MenuToggle initial={isHome ? "menu" : "monogram"} />
        </Cluster>
      </Container>
    )
  }

  <!-- MOBILE NAVIGATION -->

  <template x-teleport="body">
    <div
      data-color-scheme="light"
      id="mobile-menu"
      role="dialog"
      aria-modal="true"
      aria-label="Site navigation"
      x-show="menuOpen"
      x-cloak
      @keydown.escape.window="menuOpen = false"
      x-transition:enter="mobile-nav-enter"
      x-transition:enter-start="mobile-nav-from"
      x-transition:enter-end="mobile-nav-to"
      x-transition:leave="mobile-nav-leave"
      x-transition:leave-start="mobile-nav-to"
      x-transition:leave-end="mobile-nav-from"
      class="mobile-nav"
    >
      <div class="mobile-nav-inner">
        <Cluster class="mobile-nav-header" justify="between">
          <a href="/" aria-label="Home" class="mobile-nav-logo">
            <MonogramIcon />
          </a>

          <button
            x-ref="closeBtn"
            class="mobile-nav-close"
            @click="menuOpen = false"
            aria-label="Close navigation menu"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.25"
              stroke-linecap="round"
              aria-hidden="true"
            >
              <line x1="18" y1="6" x2="6" y2="18"></line>
              <line x1="6" y1="6" x2="18" y2="18"></line>
            </svg>
          </button>
        </Cluster>

        <nav class="mobileNavLinks" aria-label="Main navigation">
          <ul set:html={mobileNavLinksHtml} />
        </nav>
      </div>
    </div>
  </template>
</Section>

<style>
  .site-header {
    position: fixed;
    width: 100%;
    top: 0;
    z-index: 100;
    /* background-color: transparent; */
    transition: background-color 300ms var(--ease-out, ease);

    &[data-scrolled="true"] {
      /* background-color: color-mix(in oklab, var(--color-bg) 92%, transparent); */
      /* background-color: var(--color-bg); */
    }
  }

  .container {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    padding-block: var(--space-md);
  }

  nav {
    a {
      font-family: var(--font-family-heading);
      font-size: var(--font-size-3);
      text-transform: uppercase;
      color: var(--color-foreground);

      &:hover {
        &:hover {
          color: var(--color-accent);
        }
      }
    }
  }

  .menuToggle {
    display: flex;
    align-items: center;
    justify-content: center;
    background: none;
    border: none;
    color: var(--color-foreground);
    cursor: pointer;
    position: relative;
    padding: 0;

    &:hover {
      .menuToggle-icon {
        opacity: 0;
      }
      .menuToggle-monogram {
        opacity: 1;
        display: block;
      }
    }

    /* svg {
      width: 1.75rem;
      height: 1.75rem;
    } */

    .menuToggle-icon {
    }
    .menuToggle-monogram {
      opacity: 0;
      display: none;
      position: absolute;
      left: 50%;
      transform: translateX(-50%);
      top: 0;
    }
  }
</style>

<style>
  /* Transition helpers applied by Alpine x-transition */
  .mobile-nav-enter {
    transition:
      transform 900ms cubic-bezier(0.22, 1, 0.36, 1),
      opacity 700ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .mobile-nav-leave {
    transition:
      transform 700ms cubic-bezier(0.4, 0, 0.2, 1),
      opacity 500ms cubic-bezier(0.4, 0, 0.2, 1);
  }

  .mobile-nav-from {
    transform: translateY(-1.5rem);
    opacity: 0;
  }

  .mobile-nav-to {
    transform: translateY(0);
    opacity: 1;
  }

  /* Full-screen overlay */
  .mobile-nav {
    position: fixed;
    inset: 0;
    z-index: 200;
    overflow-y: auto;
    overscroll-behavior: contain;
    top: 0;

    .mobile-nav-inner {
      display: flex;
      flex-direction: column;
      min-height: 100%;
      padding-block: var(--space-md);
      padding-inline: var(--container-padding);
    }

    /* Top bar — logo + close */
    .mobile-nav-header {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
    }

    .mobile-nav-logo {
      display: block;
      /* color: currentColor;

      svg {
        height: 2.5rem;
        width: auto;
      } */
    }

    .mobile-nav-close {
      display: flex;
      align-items: center;
      justify-content: center;
      background: none;
      border: none;
      color: currentColor;
      cursor: pointer;
      padding: var(--space-2xs);

      svg {
        width: 1.75rem;
        height: 1.75rem;
      }

      &:hover {
        opacity: 0.6;
      }
    }

    /* Nav links — pinned to bottom-left */
    .mobileNavLinks {
      flex: 1;
      display: flex;
      align-items: flex-end;
      justify-content: flex-start;
      /* padding-block: var(--space-xl); */

      /* ul {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
        flex-direction: column;
      } */

      ul {
        &:hover {
          :global(a) {
            opacity: 0.4;
          }
        }
      }

      :global(a) {
        display: block;
        font-family: var(--font-family-heading);
        /* font-weight: var(--font-weight-thin); */
        /* font-size: 42px; */
        font-size: var(--font-size-3);
        line-height: var(--line-height-snug);
        letter-spacing: var(--letter-spacing-looser);
        text-transform: uppercase;
        color: currentColor;
        text-decoration: none;
        transition: 0.5s all var(--ease);
      }
      :global(a:hover) {
        opacity: 1 !important;
      }
    }
  }

  header + :global(.section) {
    margin-top: var(--header-height);
  }
</style>
