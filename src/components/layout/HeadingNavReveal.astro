---
import Heading from "@components/display/Heading.astro";
import settings from "../../content/settings.json";
import type { FontSizeToken } from "../../types";

interface Props {
  as?: "h1" | "h2" | "h3";
  size?: FontSizeToken;
  class?: string;
}

const { as = "h2", size = "3", class: className } = Astro.props;

const pathname = Astro.url.pathname.replace(/\/$/, "") || "/";
const navLinks = (settings.navLinks ?? []).filter(link => {
  const href = link.href.replace(/\/$/, "") || "/";
  return href !== pathname;
});
---

<div
  class:list={["headingNavReveal", className]}
  x-data="{ open: false }"
  @mouseenter="open = true"
  @mouseleave="open = false"
  @click.outside="open = false"
>
  {
    navLinks.length > 0 && (
      <nav
        class="headingNavReveal-links"
        aria-label="Section navigation"
        :class="{ 'is-open': open }"
        :aria-hidden="(!open).toString()"
      >
        <ul>
          {navLinks.map((link, i) => (
            <li style={`--stagger-index: ${navLinks.length - 1 - i}`}>
              <Heading as={as} size={size} class="headingNavReveal-item">
                <a href={link.href}>{link.label}</a>
              </Heading>
            </li>
          ))}
        </ul>
      </nav>
    )
  }
  <div class="headingNavReveal-trigger" @click="open = !open">
    <slot />
  </div>
</div>

<style>
  .headingNavReveal {
    position: relative;
  }

  .headingNavReveal::before {
    content: "";
    position: fixed;
    inset: 0;
    background-color: color-mix(in oklab, var(--color-bg) 80%, transparent);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    opacity: 0;
    pointer-events: none;
    transition: opacity 400ms var(--easing, ease);
    z-index: 1;
  }

  @media (--sm) {
    .headingNavReveal:has(.headingNavReveal-links.is-open)::before {
      opacity: 1;
    }
  }

  .headingNavReveal-trigger {
    position: relative;
    z-index: 2;
    cursor: pointer;
    -webkit-tap-highlight-color: transparent;
  }

  .headingNavReveal-links {
    position: absolute;
    bottom: 100%;
    left: 0;
    padding-block-end: var(--space-md);
    z-index: 3;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition:
      opacity 400ms var(--easing, ease),
      visibility 0s linear 400ms;
  }

  .headingNavReveal-links.is-open {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
    transition:
      opacity 400ms var(--easing, ease),
      visibility 0s linear 0s;
  }

  .headingNavReveal-links ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    width: max-content;
    max-width: 100vw;
  }

  .headingNavReveal-item {
    white-space: nowrap;
  }

  .headingNavReveal-links li {
    opacity: 0;
    transform: translateY(1rem);
    transition:
      opacity 800ms cubic-bezier(0.22, 1, 0.36, 1),
      transform 800ms cubic-bezier(0.22, 1, 0.36, 1);
    transition-delay: 0ms;
    will-change: opacity, transform;
  }

  .headingNavReveal-links.is-open li {
    opacity: 1;
    transform: translateY(0);
    transition-delay: calc(var(--stagger-index, 0) * 80ms);
  }

  .headingNavReveal-item {
    transition:
      opacity 600ms var(--easing, ease),
      color 400ms var(--easing, ease);
  }

  .headingNavReveal-item :global(a) {
    color: inherit;
    text-decoration: none;
    display: block;
  }

  .headingNavReveal-links ul:hover li:not(:hover) .headingNavReveal-item {
    opacity: 0.4;
  }

  .headingNavReveal-links li:hover .headingNavReveal-item {
    color: var(--color-accent);
  }

  .headingNavReveal-trigger {
    transition: opacity 600ms var(--easing, ease);
  }

  .headingNavReveal:has(.headingNavReveal-links li:hover) .headingNavReveal-trigger {
    opacity: 0.4;
  }
</style>
